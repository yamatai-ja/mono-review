---
const { title, rating, pros: rawPros, cons: rawCons, image, description } = Astro.props;

// 文字列（複数行テキスト）または配列を処理
const pros = typeof rawPros === "string" ? rawPros.split("\n").filter(t => t.trim() !== "") : rawPros;
const cons = typeof rawCons === "string" ? rawCons.split("\n").filter(t => t.trim() !== "") : rawCons;

// 星の表示用配列を作成
const fullStars = Math.floor(rating);
const hasHalfStar = rating % 1 >= 0.5;
const emptyStars = 5 - fullStars - (hasHalfStar ? 1 : 0);

// 構造化データ (JSON-LD)
const reviewSchema = {
  "@context": "https://schema.org/",
  "@type": "Product",
  "name": title,
  "image": image,
  "description": description,
  "review": {
    "@type": "Review",
    "reviewRating": {
      "@type": "Rating",
      "ratingValue": rating,
      "bestRating": "5",
      "worstRating": "1"
    },
    "author": {
      "@type": "Person",
      "name": "T.Y"
    }
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": rating,
    "reviewCount": "1"
  }
};
---

<div class="review-score-card my-12 overflow-hidden rounded-xl border border-border bg-white shadow-sm">
  <div class="bg-light px-6 py-4 border-b border-border">
    <h3 class="h4 mb-0 flex items-center">
      <svg xmlns="http://www.w3.org/2000/svg" class="mr-2 text-primary" width="1.2em" height="1.2em" viewBox="0 0 24 24" fill="currentColor"><path d="m12 17.27 4.15 2.51c.76.46 1.69-.22 1.49-1.08l-1.1-4.72 3.67-3.18c.67-.58.31-1.68-.57-1.75l-4.83-.41-1.89-4.46c-.34-.81-1.5-.81-1.84 0L9.19 8.63l-4.83.41c-.88.07-1.24 1.17-.57 1.75l3.67 3.18-1.1 4.72c-.2.86.73 1.54 1.49 1.08l4.15-2.51z"/></svg>
      レビューまとめ：{title}
    </h3>
  </div>
  
  <div class="p-6 md:p-8">
    <div class="row items-center">
      <div class="md:col-4 text-center border-b md:border-b-0 md:border-r border-border pb-6 md:pb-0">
        <div class="text-5xl font-bold text-dark mb-2">{rating.toFixed(1)}</div>
        <div class="flex justify-center text-primary text-2xl mb-2">
          {[...Array(fullStars)].map(() => (
            <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="currentColor"><path d="m12 17.27 4.15 2.51c.76.46 1.69-.22 1.49-1.08l-1.1-4.72 3.67-3.18c.67-.58.31-1.68-.57-1.75l-4.83-.41-1.89-4.46c-.34-.81-1.5-.81-1.84 0L9.19 8.63l-4.83.41c-.88.07-1.24 1.17-.57 1.75l3.67 3.18-1.1 4.72c-.2.86.73 1.54 1.49 1.08l4.15-2.51z"/></svg>
          ))}
          {hasHalfStar && (
            <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="currentColor"><path d="m12 15.4-3.76 2.27 1-4.28-3.32-2.88 4.38-.38L12 6.1l1.71 4.04 4.38.38-3.32 2.88 1 4.28L12 15.4zM12 2L9.19 8.63l-4.83.41c-.88.07-1.24 1.17-.57 1.75l3.67 3.18-1.1 4.72c-.2.86.73 1.54 1.49 1.08l4.15-2.51 4.15 2.51c.76.46 1.69-.22 1.49-1.08l-1.1-4.72 3.67-3.18c.67-.58.31-1.68-.57-1.75l-4.83-.41L14.81 2 12 2z"/></svg>
          )}
          {[...Array(emptyStars)].map(() => (
            <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-30"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
          ))}
        </div>
        <div class="text-sm text-text-light font-medium uppercase tracking-wider">Total Score</div>
      </div>
      
      <div class="md:col-8 mt-8 md:mt-0 md:pl-8">
        <div class="row">
          <div class="col-6">
            <h4 class="h6 mb-3 flex items-center text-primary">
              <svg xmlns="http://www.w3.org/2000/svg" class="mr-1" width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
              良かった点
            </h4>
            <ul class="list-none p-0 text-sm space-y-2">
              {pros && pros.map((pro: string) => (
                <li class="flex items-start">
                  <span class="mr-2 mt-1 h-1.5 w-1.5 rounded-full bg-primary flex-shrink-0"></span>
                  {pro}
                </li>
              ))}
            </ul>
          </div>
          <div class="col-6">
            <h4 class="h6 mb-3 flex items-center text-red-500">
              <svg xmlns="http://www.w3.org/2000/svg" class="mr-1" width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
              気になる点
            </h4>
            <ul class="list-none p-0 text-sm space-y-2">
              {cons && cons.map((con: string) => (
                <li class="flex items-start">
                  <span class="mr-2 mt-1 h-1.5 w-1.5 rounded-full bg-red-500 flex-shrink-0"></span>
                  {con}
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script type="application/ld+json" set:html={JSON.stringify(reviewSchema)} />
