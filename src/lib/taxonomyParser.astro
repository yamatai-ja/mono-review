---
import { getSinglePage } from "@/lib/contentParser.astro";
import { slugify } from "@/lib/utils/textConverter";
import { toTaxonomyTerm, type TaxonomyTerm } from "@/lib/utils/taxonomy";

export const getTaxonomyTerms = async (
  collection: any,
  name: string,
): Promise<TaxonomyTerm[]> => {
  const singlePages = await getSinglePage(collection);
  const terms = new Map<string, TaxonomyTerm>();

  for (const page of singlePages as any[]) {
    const values = page.data[name];
    if (!Array.isArray(values)) continue;

    for (const value of values) {
      const term = toTaxonomyTerm(value);
      if (term.id && term.name && !terms.has(term.id)) terms.set(term.id, term);
    }
  }

  return [...terms.values()];
};

// get taxonomy from frontmatter
export const getTaxonomy = async (collection: any, name: string) => {
  const singlePages = await getSinglePage(collection);
  const taxonomyPages = singlePages.map((page: any) => page.data[name]);
  let taxonomies: string[] = [];
  for (let i = 0; i < taxonomyPages.length; i++) {
    const categoryArray = taxonomyPages[i];
    if (!categoryArray) continue;
    for (let j = 0; j < categoryArray.length; j++) {
      const item = categoryArray[j];
      if (typeof item === "object" && item !== null && item.id) {
        const id = String(item.id).trim();
        if (id) taxonomies.push(id);
      } else if (typeof item === "string") {
        const slug = slugify(item);
        if (slug) taxonomies.push(slug);
      }
    }
  }
  const taxonomy = [...new Set(taxonomies)];
  return taxonomy;
};

// get all taxonomies from frontmatter
export const getAllTaxonomy = async (collection: any, name: string) => {
  const singlePages = await getSinglePage(collection);
  const taxonomyPages = singlePages.map((page: any) => page.data[name]);
  let taxonomies: string[] = [];
  for (let i = 0; i < taxonomyPages.length; i++) {
    const categoryArray = taxonomyPages[i];
    if (!categoryArray) continue;
    for (let j = 0; j < categoryArray.length; j++) {
      const item = categoryArray[j];
      if (typeof item === "object" && item !== null && item.id) {
        const id = String(item.id).trim();
        if (id) taxonomies.push(id);
      } else if (typeof item === "string") {
        const slug = slugify(item);
        if (slug) taxonomies.push(slug);
      }
    }
  }
  return taxonomies;
};
---

