---
import { getSinglePage } from "@/lib/contentParser.astro";
import { type BlogListCard, resolvePostImageSrc } from "@/lib/utils/blogListCard";
import dateFormat from "@/lib/utils/dateFormat";
import { humanize, slugify } from "@/lib/utils/textConverter";
import { Image } from "astro:assets";

type Props = {
  posts: BlogListCard[];
  className?: string;
  fluid?: boolean;
};

const authors = await getSinglePage("authors");
const { className, posts, fluid } = Astro.props;
---

<div
  class={`row gy-5 gx-4 ${className} ${posts.length == 1 ? "justify-center" : ""} `}
>
  {
    posts.map((post, i: number) => (
      <div class={i === 0 && fluid != false ? "col-12" : "col-12 sm:col-6"}>
        {resolvePostImageSrc(post.image) && (
          <a
            href={`${import.meta.env.BASE_URL}blog/${post.id}`}
            class="rounded-lg block hover:text-primary overflow-hidden group"
          >
            <Image
              class="group-hover:scale-[1.03] transition duration-300 w-full"
              src={resolvePostImageSrc(post.image)!}
              alt={post.title}
              width={i === 0 ? 925 : 445}
              height={i === 0 ? 475 : 230}
            />
          </a>
        )}
        <ul class="mt-6 mb-4 flex flex-wrap items-center text-text">
          <li class="mr-5">
            {authors
              .filter((author) =>
                post.authors
                  .map((a) => slugify(a))
                  .includes(slugify(author.data.title))
              )
              .map((author) => (
                <a
                  href={`${import.meta.env.BASE_URL}authors/${slugify(author.data.title)}`}
                  class="flex items-center hover:text-primary font-medium"
                >
                  {author.data.image && (
                    <Image
                      src={import.meta.env.BASE_URL + author.data.image.replace(/^\//, "")}
                      alt={author.data.title}
                      height={50}
                      width={50}
                      class="mr-2 h-6 w-6 rounded-full"
                    />
                  )}
                  <span>{author.data.title}</span>
                </a>
              ))}
          </li>
          <li class="mr-5 flex items-center flex-wrap font-medium">
            <svg xmlns="http://www.w3.org/2000/svg" class="inline mr-1" width="1em" height="1em" viewBox="0 0 24 24" fill="currentColor"><path d="M20 3h-1V1h-2v2H7V1H5v2H4C2.9 3 2 3.9 2 5v16c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 18H4V8h16v13z"/><path d="m9.08 16.17 1.41 1.41 4.59-4.58-1.41-1.42z"/></svg>{dateFormat(new Date(post.date))}
          </li>
          <li class="mr-5 flex items-center flex-wrap">
            <svg xmlns="http://www.w3.org/2000/svg" class="inline mr-1" width="1em" height="1em" viewBox="0 0 24 24" fill="currentColor"><path d="M3 3h8v8H3zm10 0h8v8h-8zM3 13h8v8H3zm13 0h2v3h3v2h-3v3h-2v-3h-3v-2h3z"/></svg>
            <ul>
              {post.categories.map((category, idx: number) => {
                const isObj = (typeof category === "object" && category !== null && "id" in category);
                const catId = isObj ? (category as any).id : slugify(category as string);
                const catName = isObj ? (category as any).name : humanize(category as string);
                
                return (
                  <li class="inline-block">
                    <a
                      href={`${import.meta.env.BASE_URL}categories/${catId}`}
                      class="mr-2 hover:text-primary font-medium"
                    >
                      {catName}
                      {idx !== post.categories.length - 1 && ","}
                    </a>
                  </li>
                );
              })}
            </ul>
          </li>
        </ul>
        <h3 class="mb-4">
          <a
            href={`${import.meta.env.BASE_URL}blog/${post.id}`}
            class="block hover:text-primary transition duration-300"
          >
            {post.title}
          </a>
        </h3>
        <p class="text-text line-clamp-2">{post.excerpt}</p>
      </div>
    ))
  }
</div>
