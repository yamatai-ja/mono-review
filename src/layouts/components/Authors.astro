---
import { markdownify } from "@/lib/utils/textConverter";
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";

type Props = {
  authors: CollectionEntry<"authors">[];
};
const { authors } = Astro.props;
---

<div class="row justify-center">
  {
    authors.map((author) => (
      <div class="col-12 mb-8 sm:col-6 md:col-4">
        {author.data.image && (
          <div class="mb-4">
            <Image
              src={author.data.image}
              alt={author.data.title}
              height={150}
              width={150}
              class="mx-auto rounded-lg"
            />
          </div>
        )}
        <h3 class="h4 mt-8 mb-3">
          <a
            href={`${import.meta.env.BASE_URL}authors/${author.id}`}
            class="block hover:text-primary transition duration-200"
          >
            {author.data.title}
          </a>
        </h3>
        {author.body && (
          <p class="mb-3" set:text={markdownify(author.body.slice(0, 100))} />
        )}

        <a
          href={`${import.meta.env.BASE_URL}authors/${author.id}`}
          class="inline-flex items-center text-primary transition duration-200 hover:opacity-70"
        >
          Read More <svg xmlns="http://www.w3.org/2000/svg" class="inline ml-2" width="1em" height="1em" viewBox="0 0 16 16" fill="currentColor"><path fill-rule="evenodd" d="M8 15A7 7 0 1 0 8 1a7 7 0 0 0 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/><path fill-rule="evenodd" d="M4 8a.5.5 0 0 0 .5.5h5.793l-2.147 2.146a.5.5 0 0 0 .708.708l3-3a.5.5 0 0 0 0-.708l-3-3a.5.5 0 0 0-.708.708L10.293 7.5H4.5A.5.5 0 0 0 4 8z"/></svg></a>
      </div>
    ))
  }
</div>

