---
import { type BlogListCard, resolvePostImageSrc } from "@/lib/utils/blogListCard";
import dateFormat from "@/lib/utils/dateFormat";
import { humanize, slugify } from "@/lib/utils/textConverter";
import { Image } from "astro:assets";

type Props = {
  posts: BlogListCard[];
};
const { posts } = Astro.props;
---

<div class="row gy-4 justify-center">
  {
    posts.map((post, i: number) => (
      <div class={`col-12 sm:col-6 md:col-4 ${i === 2 && "hidden md:block"}`}>
        {resolvePostImageSrc(post.image) && (
          <a
            href={`${import.meta.env.BASE_URL}blog/${post.id}`}
            class="rounded-lg block hover:text-primary overflow-hidden group"
          >
            <Image
              class="group-hover:scale-[1.05] transition duration-300 w-full"
              src={resolvePostImageSrc(post.image)!}
              alt={post.title}
              width={445}
              height={230}
            />
          </a>
        )}
        <ul class="mt-4 text-text flex flex-wrap items-center text-sm">
          <li class="mb-2 mr-4 flex items-center flex-wrap font-medium">
            <svg xmlns="http://www.w3.org/2000/svg" class="inline mr-1" width="1em" height="1em" viewBox="0 0 24 24" fill="currentColor"><path d="M20 3h-1V1h-2v2H7V1H5v2H4C2.9 3 2 3.9 2 5v16c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 18H4V8h16v13z"/><path d="m9.08 16.17 1.41 1.41 4.59-4.58-1.41-1.42z"/></svg>{dateFormat(post.date)}
          </li>
          <li class="mb-2 mr-4 flex items-center flex-wrap">
            <svg xmlns="http://www.w3.org/2000/svg" class="inline mr-1" width="1em" height="1em" viewBox="0 0 24 24" fill="currentColor"><path d="M3 3h8v8H3zm10 0h8v8h-8zM3 13h8v8H3zm13 0h2v3h3v2h-3v3h-2v-3h-3v-2h3z"/></svg><ul>
              {post.categories.map((category: string, idx: number) => (
                <li class="inline-block">
                  <a
                    href={`${import.meta.env.BASE_URL}categories/${slugify(category)}`}
                    class="mr-2 hover:text-primary font-medium"
                  >
                    {humanize(category)}
                    {idx !== post.categories.length - 1 && ","}
                  </a>
                </li>
              ))}
            </ul>
          </li>
        </ul>
        <h3 class="h5">
          <a
            href={`${import.meta.env.BASE_URL}blog/${post.id}`}
            class="block hover:text-primary transition duration-300"
          >
            {post.title}
          </a>
        </h3>
      </div>
    ))
  }
</div>
