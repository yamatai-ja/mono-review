---
import { type BlogListCard, resolvePostImageSrc } from "@/lib/utils/blogListCard";
import dateFormat from "@/lib/utils/dateFormat";
import { humanize, slugify } from "@/lib/utils/textConverter";
import { Image } from "astro:assets";

type Props = {
  posts: BlogListCard[];
};
const { posts } = Astro.props;
---

<div class="row gy-4">
  {
    posts.map((post, i: number) => (
      <div class={`col-12 sm:col-6 md:col-4 ${i === 2 && "hidden md:block"}`}>
        <div class="group h-full rounded-xl border border-border bg-white p-4 transition-all duration-300 hover:border-primary hover:shadow-lg">
          {resolvePostImageSrc(post.image) && (
            <a
              href={`${import.meta.env.BASE_URL}blog/${post.id}`}
              class="relative block aspect-video overflow-hidden rounded-lg"
            >
              <Image
                class="h-full w-full object-cover transition duration-500 group-hover:scale-110"
                src={resolvePostImageSrc(post.image)!}
                alt={post.title}
                width={445}
                height={230}
              />
              <span class="absolute left-2 top-2 rounded bg-primary px-2 py-1 text-[10px] font-bold text-white shadow-sm">
                RELATED
              </span>
            </a>
          )}
          <div class="mt-4">
            <ul class="flex flex-wrap items-center text-[11px] font-medium text-light">
              <li class="mr-3 flex items-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="mr-1" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
                {dateFormat(post.date)}
              </li>
              {post.categories.length > 0 && (
                <li class="flex items-center">
                  <svg xmlns="http://www.w3.org/2000/svg" class="mr-1" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path><line x1="7" y1="7" x2="7.01" y2="7"></line></svg>
                  {humanize(post.categories[0])}
                </li>
              )}
            </ul>
            <h3 class="mt-2 text-base font-bold leading-snug md:text-lg">
              <a
                href={`${import.meta.env.BASE_URL}blog/${post.id}`}
                class="block hover:text-primary transition-colors duration-300"
              >
                {post.title}
              </a>
            </h3>
          </div>
        </div>
      </div>
    ))
  }
</div>
