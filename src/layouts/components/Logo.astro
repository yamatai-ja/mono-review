---
import { Image } from "astro:assets";
import config from "@/config/config.json";
const { src } = Astro.props;
const {
  logo,
  logo_width,
  logo_height,
  logo_text,
  title,
}: {
  logo: string;
  logo_width: any;
  logo_height: any;
  logo_text: string;
  title: string;
} = config.site;
---

<a href={import.meta.env.BASE_URL} class="navbar-brand block">
  {
    src || logo ? (
      <Image
        width={logo_width.replace("px", "") * 2}
        height={logo_height.replace("px", "") * 2}
        src={import.meta.env.BASE_URL + (src ? src : logo).replace(/^\//, "")}
        alt={title}
        style={{
          height: logo_height.replace("px", "") + "px",
          width: logo_width.replace("px", "") + "px",
        }}
      />
    ) : logo_text ? (
      <span style={{ 
        fontSize: "28px", 
        color: "#000", 
        lineHeight: "1", 
        display: "inline-flex", 
        alignItems: "center",
        fontFamily: "'Montserrat', sans-serif",
        letterSpacing: "-0.04em"
      }}>
        <span style={{ fontWeight: "800" }}>Mono's</span>
        <span style={{ fontWeight: "300", marginLeft: "6px" }}>Log</span>
      </span>
    ) : (
      title
    )
  }
</a>

