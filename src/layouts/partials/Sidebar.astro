---
import { Image } from "astro:assets";
import config from "@/config/config.json";
import { resolvePostImageSrc } from "@/lib/utils/blogListCard";
import dateFormat from "@/lib/utils/dateFormat";
import { humanize, slugify } from "@/lib/utils/textConverter";

const { headings, latestPosts } = Astro.props;

// プロフィール情報
const profile = {
  name: "T.Y",
  image: "/images/author.png", // 後で画像を変更可能
  bio: "AI（Gemini/GPT）を駆使して「モノの深掘り」を記録するエンジニア・ブロガー。ガジェット、スポーツ、日用品の徹底検証を『図録』として発信中。"
};

// おすすめランキング（とりあえず最新の中から3つをピックアップ、後で手動指定可能）
const popularPosts = latestPosts.slice(0, 3);
---

<aside class="space-y-8">
  <!-- 検索ボックス -->
  <div class="bg-white p-6 rounded-lg border border-border shadow-sm">
    <form action={import.meta.env.BASE_URL + "search"} method="GET" class="relative">
      <input
        type="text"
        name="key"
        placeholder="キーワードを入力..."
        class="w-full rounded-full border border-border px-4 py-2 text-sm focus:border-primary focus:outline-none"
      />
      <button type="submit" class="absolute right-3 top-2.5 text-text-light hover:text-primary">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
      </button>
    </form>
  </div>
  <!-- プロフィール -->
  <div class="bg-light p-6 rounded-lg border border-border text-center">
    <div class="mb-4 flex justify-center">
      <Image
        src={profile.image}
        alt={profile.name}
        width={100}
        height={100}
        class="rounded-full border-4 border-white shadow-sm h-24 w-24 object-cover"
      />
    </div>
    <h3 class="h5 mb-2">{profile.name}</h3>
    <p class="text-sm text-text mb-4 leading-relaxed">
      {profile.bio}
    </p>
    <a href="/about" class="btn btn-outline-primary btn-sm w-full">詳しく見る</a>
  </div>

  <!-- 目次 (Sticky) -->
  {headings && headings.length > 0 && (
    <div class="toc-sidebar sticky top-24 p-6 bg-white rounded-lg border border-border shadow-sm hidden lg:block">
      <h3 class="h6 mb-4 border-b pb-2 flex items-center">
        <svg xmlns="http://www.w3.org/2000/svg" class="mr-2" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"></line><line x1="8" y1="12" x2="21" y2="12"></line><line x1="8" y1="18" x2="21" y2="18"></line><line x1="3" y1="6" x2="3.01" y2="6"></line><line x1="3" y1="12" x2="3.01" y2="12"></line><line x1="3" y1="18" x2="3.01" y2="18"></line></svg>
        目次
      </h3>
      <ul class="space-y-3 text-sm" id="toc-list">
        {headings.map((h: any) => (
          <li class={h.level === 3 ? "ml-4 text-text-light" : "font-medium text-dark"}>
            <a 
              href={`#${h.id}`} 
              data-toc-link 
              class="hover:text-primary transition-colors duration-200 block border-l-2 border-transparent pl-3"
            >
              {h.text}
            </a>
          </li>
        ))}
      </ul>
    </div>
  )}

<script>
  // 目次のハイライト機能
  const observerOptions = {
    root: null,
    rootMargin: '-10% 0px -80% 0px',
    threshold: 0
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const id = entry.target.getAttribute('id');
        const activeLink = document.querySelector(`[data-toc-link][href="#${id}"]`);
        
        // 全てのリンクから active クラスを削除
        document.querySelectorAll('[data-toc-link]').forEach(link => {
          link.classList.remove('text-primary', 'font-bold', 'border-primary');
          link.classList.add('border-transparent');
        });

        // 現在の見出しに active クラスを付与
        if (activeLink) {
          activeLink.classList.add('text-primary', 'font-bold', 'border-primary');
          activeLink.classList.remove('border-transparent');
        }
      }
    });
  }, observerOptions);

  // 記事内の見出し（h2, h3）を監視
  document.querySelectorAll('article h2, article h3').forEach(heading => {
    observer.observe(heading);
  });
</script>

  <!-- 新着記事 -->
  <div class="p-6 bg-white rounded-lg border border-border shadow-sm">
    <h3 class="h6 mb-4 border-b pb-2">新着記事</h3>
    <div class="space-y-4">
      {latestPosts.slice(0, 5).map((post: any) => (
        <a href={`${import.meta.env.BASE_URL}blog/${post.id}`} class="group flex gap-3 items-start">
          <div class="flex-shrink-0 w-20 h-14 overflow-hidden rounded">
            <Image
              src={resolvePostImageSrc(post.image?.url) || "/images/author.png"}
              alt={post.title}
              width={80}
              height={56}
              class="w-full h-full object-cover group-hover:scale-110 transition duration-300"
            />
          </div>
          <div class="flex-grow">
            <h4 class="text-xs font-bold leading-tight group-hover:text-primary transition duration-200 line-clamp-2">
              {post.title}
            </h4>
            <span class="text-[10px] text-text-light">{dateFormat(post.publishedAt)}</span>
          </div>
        </a>
      ))}
    </div>
  </div>

  <!-- おすすめランキング -->
  <div class="p-6 bg-white rounded-lg border border-border shadow-sm">
    <h3 class="h6 mb-4 border-b pb-2">おすすめ記事</h3>
    <div class="space-y-4">
      {popularPosts.map((post: any, index: number) => (
        <a href={`${import.meta.env.BASE_URL}blog/${post.id}`} class="group flex gap-3 items-center">
          <div class="flex-shrink-0 w-8 h-8 flex items-center justify-center rounded-full bg-light text-primary font-bold text-sm">
            {index + 1}
          </div>
          <h4 class="text-xs font-bold leading-tight group-hover:text-primary transition duration-200 line-clamp-2">
            {post.title}
          </h4>
        </a>
      ))}
    </div>
  </div>

  <!-- サイドバー広告 -->
  {config.adsense.ad_sidebar && (
    <div class="p-4 bg-white rounded-lg border border-border shadow-sm text-center">
      <p class="text-[10px] text-text-light mb-2">SPONSORED</p>
      <div set:html={config.adsense.ad_sidebar} />
    </div>
  )}
</aside>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .toc-sidebar {
    max-height: calc(100vh - 120px);
    overflow-y: auto;
  }
</style>
