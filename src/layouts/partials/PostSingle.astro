---
import Share from "@/components/Share.astro";
import SimilarPosts from "@/components/SimilarPosts.astro";
import config from "@/config/config.json";
import { getSinglePage } from "@/lib/contentParser.astro";
import type { MicroCMSContent } from "@/lib/microcms/types";
import {
  microCMSContentToBlogListCard,
  microCMSBodyHtml,
  pickCategories,
  pickTags,
  resolvePostImageSrc,
  type MicroCMSBlogPostFields,
} from "@/lib/utils/blogListCard";
import dateFormat from "@/lib/utils/dateFormat";
import { humanize, plainify, slugify } from "@/lib/utils/textConverter";
import { Image } from "astro:assets";
import ProductCard from "@/components/ProductCard.astro";

type Props = {
  article: MicroCMSContent<MicroCMSBlogPostFields>;
  allPosts: MicroCMSContent<MicroCMSBlogPostFields>[];
};

const allAuthors = await getSinglePage("authors");
const { article, allPosts } = Astro.props;

const rawBodyHtml = microCMSBodyHtml(article);

// 目次の抽出と本文へのID付与
const headings: { text: string; id: string; level: number }[] = [];
const bodyHtml = rawBodyHtml.replace(/<h([23])(.*?)>(.*?)<\/h\1>/g, (match, level, attrs, text) => {
  const id = slugify(plainify(text));
  headings.push({ text: plainify(text), id, level: parseInt(level) });
  return `<h${level}${attrs} id="${id}">${text}</h${level}>`;
});

const { title, description, authors, categories, image } = article;
const tagList = pickTags(article.tags);
const categoryList = pickCategories(categories);
const heroSrc = resolvePostImageSrc(
  typeof image === "string" ? image : image?.url,
);

const shareSlug = `${config.site.base_path.replace(/^\/|\/$/g, "")}/blog/${article.id}`;

const catSet = new Set(categoryList);
const tagSet = new Set(tagList);
const similarCards =
  catSet.size === 0 && tagSet.size === 0
    ? []
    : allPosts
        .filter((p) => {
          if (p.id === article.id) return false;
          const pc = pickCategories(p.categories);
          const pt = pickTags(p.tags);
          return (
            pc.some((c: string) => catSet.has(c)) ||
              pt.some((t: string) => tagSet.has(t))
          );
        })
        .map(microCMSContentToBlogListCard)
        .slice(0, 10);

const displaySimilar = similarCards.slice(0, 3);

const metaDescription = description
  ? plainify(description)
  : plainify(bodyHtml.slice(0, 500));
---

<section class="section">
  <div class="container">
    <article class="row justify-center">
      <div class="md:col-10 text-center">
        <h1 class="h2">{title}</h1>
        <ul class="mt-4 flex flex-wrap items-center justify-center text-text">
          <li class="mx-3">
            {
              allAuthors
                .filter((author) =>
                  (authors ?? [])
                    .map((a: string) => slugify(a))
                    .includes(slugify(author.data.title))
                )
                .map((author) => (
                  <a
                    href={`${import.meta.env.BASE_URL}authors/${slugify(author.data.title)}`}
                    class="flex items-center hover:text-primary font-medium"
                  >
                    {author.data.image && (
                      <Image
                        src={
                          resolvePostImageSrc(author.data.image) ??
                          author.data.image
                        }
                        alt={author.data.title}
                        height={50}
                        width={50}
                        class="mr-2 h-6 w-6 rounded-full"
                      />
                    )}
                    <span>{author.data.title}</span>
                  </a>
                ))
            }
          </li>
          <li class="mx-3 flex items-center flex-wrap font-medium">
            <svg xmlns="http://www.w3.org/2000/svg" class="inline mr-1" width="1em" height="1em" viewBox="0 0 24 24" fill="currentColor"><path d="M20 3h-1V1h-2v2H7V1H5v2H4C2.9 3 2 3.9 2 5v16c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 18H4V8h16v13z"/><path d="m9.08 16.17 1.41 1.41 4.59-4.58-1.41-1.42z"/></svg>{dateFormat(article.publishedAt)}
          </li>
          <li class="mx-3 flex items-center flex-wrap">
            <svg xmlns="http://www.w3.org/2000/svg" class="inline mr-1" width="1em" height="1em" viewBox="0 0 24 24" fill="currentColor"><path d="M3 3h8v8H3zm10 0h8v8h-8zM3 13h8v8H3zm13 0h2v3h3v2h-3v3h-2v-3h-3v-2h3z"/></svg><ul>
              {
                categoryList.map((category: string, i: number) => (
                  <li class="inline-block">
                    <a
                      href={`${import.meta.env.BASE_URL}categories/${slugify(category)}`}
                      class="mr-2 hover:text-primary font-medium"
                    >
                      {humanize(category)}
                      {i !== categoryList.length - 1 && ","}
                    </a>
                  </li>
                ))
              }
            </ul>
          </li>
        </ul>
      </div>

      <div class="col-12 mt-8 mb-2">
        {
          heroSrc && (
            <Image
              src={heroSrc}
              height={500}
              width={1000}
              alt={title}
              class="rounded-lg"
            />
          )
        }
      </div>

      <div class="lg:col-3 order-2 lg:order-1 mt-8">
        {headings.length > 0 && (
          <div class="toc sticky top-24 p-4 bg-light rounded-lg border border-border">
            <h4 class="h5 mb-4 border-b pb-2">目次</h4>
            <ul class="space-y-2 text-sm">
              {headings.map((h) => (
                <li class={h.level === 3 ? "ml-4" : "font-medium"}>
                  <a href={`#${h.id}`} class="hover:text-primary transition">{h.text}</a>
                </li>
              ))}
            </ul>
          </div>
        )}
      </div>

      <div class="lg:col-9 order-1 lg:order-2">
        <div class="content mb-16 text-left">
          <div set:html={bodyHtml} />
        </div>
        {
          article.products && article.products.length > 0 && (
            <div class="mt-12">
              <h2 class="h3 border-b-2 border-primary pb-2 mb-8">おすすめ商品</h2>
              {article.products.map((product) => (
                <ProductCard
                  title={product.title}
                  image={product.image?.url}
                  amazonUrl={product.amazon_url}
                  rakutenUrl={product.rakuten_url}
                  yahooUrl={product.yahoo_url}
                  price={product.price}
                />
              ))}
            </div>
          )
        }
        <div class="flex flex-wrap items-center justify-between mt-12">
          <ul class="mr-4 mb-4 space-x-3">
            {
              tagList.map((tag: string) => (
                <li class="inline-block">
                  <a
                    href={`${import.meta.env.BASE_URL}tags/${slugify(tag)}`}
                    class="block rounded-lg bg-light px-4 py-2 font-semibold text-dark text-sm hover:text-primary transition duration-300"
                  >
                    #{humanize(tag)}
                  </a>
                </li>
              ))
            }
          </ul>
          <Share
            className="social-share mb-4"
            title={title}
            description={metaDescription}
            slug={shareSlug}
          />
        </div>
      </div>
    </article>
  </div>
</section>

<style is:global>
  /* 比較表のスタイル */
  .content table {
    width: 100%;
    border-collapse: collapse;
    margin: 2rem 0;
    font-size: 0.95rem;
  }
  .content th {
    background-color: #f8f9fa;
    font-weight: bold;
    border: 1px solid #dee2e6;
    padding: 12px;
    text-align: center;
  }
  .content td {
    border: 1px solid #dee2e6;
    padding: 12px;
    vertical-align: middle;
  }

  /* 目次のレスポンシブ調整 */
  @media (max-width: 991px) {
    .toc {
      position: static;
      margin-bottom: 2rem;
    }
  }
</style>

{
  displaySimilar.length > 0 && (
    <section class="section pt-0">
      <div class="container">
        <h2 class="mb-8 text-center h3">Similar Posts</h2>
        <SimilarPosts posts={displaySimilar} />
      </div>
    </section>
  )
}
