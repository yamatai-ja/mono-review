---
import Posts from "@/components/Posts.astro";
import config from "@/config/config.json";
import Base from "@/layouts/Base.astro";
import Pagination from "@/layouts/components/Pagination.astro";
import {
  createMicroCMSClient,
  microCMSConfigFromEnv,
  microCMSPostsEndpoint,
} from "@/lib/microcms";
import {
  type MicroCMSBlogPostFields,
  microCMSContentToBlogListCard,
  sortBlogListCardsByDate,
} from "@/lib/utils/blogListCard";

const endpoint = microCMSPostsEndpoint(import.meta.env);

const client = createMicroCMSClient(microCMSConfigFromEnv(import.meta.env));
const all = await client.getAllContents<MicroCMSBlogPostFields>(endpoint, {
  orders: "-publishedAt",
});
const sortedPosts = sortBlogListCardsByDate(
  all.map(microCMSContentToBlogListCard),
);
const totalPages = Math.ceil(
  sortedPosts.length / config.settings.pagination,
);
const currentPosts = sortedPosts.slice(0, config.settings.pagination);
---

<Base>
  <section class="section">
    <div class="container">
      <Posts posts={currentPosts} className="mb-16" />
      <Pagination
        section="blog"
        currentPage={1}
        totalPages={totalPages}
      />
    </div>
  </section>
</Base>
