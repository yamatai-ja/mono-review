---
import Posts from "@/components/Posts.astro";
import Base from "@/layouts/Base.astro";
import { getSinglePage } from "@/lib/contentParser.astro";
import { getTaxonomyTerms } from "@/lib/taxonomyParser.astro";
import {
  collectionEntryToBlogListCard,
  sortBlogListCardsByDate,
} from "@/lib/utils/blogListCard";
import taxonomyFilter from "@/lib/utils/taxonomyFilter";

export async function getStaticPaths() {
  const categories = await getTaxonomyTerms("posts", "categories");

  return categories.map((category) => {
    return {
      params: { category: category.id },
      props: { categoryName: category.name },
    };
  });
}

const { category } = Astro.params;
const { categoryName } = Astro.props;

const posts = await getSinglePage("posts");
const filterByCategory = taxonomyFilter(posts, "categories", category);
const sortedPosts = sortBlogListCardsByDate(
  filterByCategory.map(collectionEntryToBlogListCard),
);

const title = categoryName || category || "";
---

<Base title={title || "Category"}>
  <div class="section">
    <div class="container">
      <p class="text-center text-2xl mb-4">Showing Posts From</p>
      <h1 class="h2 mb-16 text-center text-primary">{title}</h1>
      <Posts posts={sortedPosts} fluid={false} />
    </div>
  </div>
</Base>
